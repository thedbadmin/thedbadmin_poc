    {
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "0 = OK. Any other value means investigate pgBackRest immediately.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "green",
                  "index": 0,
                  "text": "OK"
                },
                "1": {
                  "color": "red",
                  "index": 1,
                  "text": "Missing path"
                },
                "2": {
                  "color": "red",
                  "index": 2,
                  "text": "No valid backups"
                },
                "3": {
                  "color": "red",
                  "index": 3,
                  "text": "Missing data"
                },
                "99": {
                  "color": "orange",
                  "index": 3,
                  "text": "Other"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "colorMode": "value",
